# finhealth — environment configuration template
# Copy this file to `.env` and adjust values for your local setup.

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
APP_NAME=finhealth
DEBUG=false

# ---------------------------------------------------------------------------
# Security
# ---------------------------------------------------------------------------
# Generate a real secret for production:  python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-me-in-production

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
# Async SQLite by default. The file is created on first run.
DATABASE_URL=sqlite+aiosqlite:///./finhealth.db

# ---------------------------------------------------------------------------
# CORS
# ---------------------------------------------------------------------------
# Comma-separated list of allowed origins. JSON-list style is also supported.
CORS_ORIGINS=["http://localhost:8000","http://127.0.0.1:8000"]

# ---------------------------------------------------------------------------
# LLM provider
# ---------------------------------------------------------------------------
# LLM_PROVIDER selects the concrete client implementation. Supported
# values: opencode_zen (default, curated models with free tier), ollama
# (self-hosted, CPU-friendly), opencode_go (local Go daemon).
LLM_PROVIDER=opencode_zen
# LLM_API_ENDPOINT is the base URL the provider's HTTP client targets.
# Default: OpenCode Zen. Override for other providers:
#   - Ollama (local): http://localhost:11434
#   - Ollama (docker sidecar): http://ollama:11434
#   - OpenCode Go: http://localhost:4096
#   - OpenAI: https://api.openai.com
#   - Anthropic: https://api.anthropic.com
LLM_API_ENDPOINT=https://opencode.ai/zen/v1
# LLM_API_KEY is the authentication key for the LLM provider.
# Get a key for OpenCode Zen at: https://opencode.ai/auth
# Optional for local providers like Ollama (leave empty to skip auth).
LLM_API_KEY=
# LLM_MODEL is the model name sent with every extraction request.
# Default: deepseek-v4-flash-free (free tier, good for structured output).
# Other free models on OpenCode Zen: big-pickle, mimo-v2.5-free,
#   north-mini-code-free, nemotron-3-ultra-free
# Paid models: qwen3.7-plus ($0.40/M), claude-haiku-4-5 ($1/M), etc.
# For Ollama: qwen2.5:1.5b (CPU), llama3.2:3b (CPU), phi3.5:3.8b (CPU)
LLM_MODEL=deepseek-v4-flash-free
# LLM_TIMEOUT bounds a single extraction call (seconds).
# 60s is fine for cloud APIs. Increase to 120s+ for CPU inference.
LLM_TIMEOUT=60
# LLM_MAX_RETRIES is the number of automatic retries on transient
# network/5xx errors. Set to 0 to disable retries.
LLM_MAX_RETRIES=3
# LLM_MAX_INPUT_CHARS caps the size of each PDF text chunk sent to
# the LLM. A full CMF bank statement is ~18k chars of Markdown via
# markitdown; small local models (qwen2.5:1.5b, llama3.2:1b) start
# producing malformed JSON above ~5k chars. The chunker splits the
# PDF into overlapping windows of this size and calls the LLM once
# per window — a single upload typically produces 3-4 LLM calls.
# Raise to 8000+ for paid cloud models that handle longer prompts,
# lower to 3000 for very small models. Floor is 1000.
LLM_MAX_INPUT_CHARS=5000
# LLM_CHUNK_OVERLAP_CHARS is the number of characters of overlap
# between consecutive PDF chunks sent to the LLM. Transactions
# that straddle a chunk boundary are present in full in at least
# one chunk; the orchestrator deduplicates the final list. The
# default (200) covers a full transaction row in the verbose
# Santander layout. Set to 0 to disable overlap (transactions at
# boundaries will be lost).
LLM_CHUNK_OVERLAP_CHARS=200

# ---------------------------------------------------------------------------
# OpenCode Zen (optional cloud provider, pay-as-you-go)
# ---------------------------------------------------------------------------
# OpenCode Zen is a curated list of LLM models (Claude, Qwen, Gemini,
# etc.) with transparent per-token pricing and a single API key.
# Get your API key at https://opencode.ai/auth
#
# To use it, override the LLM_* block above with:
#   LLM_PROVIDER=opencode_zen
#   LLM_API_ENDPOINT=https://opencode.ai/zen/v1
#   LLM_API_KEY=your-zen-api-key
#   LLM_MODEL=qwen3.7-plus
#
# Recommended models for finhealth (parsing structured data from PDFs):
#   qwen3.7-plus     $0.40 / $1.60 per 1M tokens  - cheap default
#   qwen3.7-max      $2.50 / $7.50 per 1M tokens  - premium quality
#   claude-haiku-4-5 $1.00 / $5.00 per 1M tokens  - good balance
#   gemini-3-flash   $0.50 / $3.00 per 1M tokens  - very cheap
#
# Zen's gateway serves the recommended models through the
# Anthropic-compatible /v1/messages endpoint, so the OpenCodeZenClient
# speaks the Anthropic request/response format. Models served through
# other Zen paths (OpenAI / Google / DeepSeek) are not yet supported.

# ---------------------------------------------------------------------------
# Deployment options
# ---------------------------------------------------------------------------
# 1. Cloud LLM provider (recommended for production):
#    - Set LLM_PROVIDER, LLM_API_ENDPOINT, LLM_API_KEY in .env
#    - Use: docker compose up -d
#
# 2. Self-hosted Ollama (CPU-friendly, no API costs):
#    - Use: docker compose -f docker-compose.self-hosted.yml up -d
#    - Pull model first: ./scripts/pull-ollama-model.sh
#    - Models recommended for CPU: qwen2.5:1.5b, llama3.2:3b, phi3.5:3.8b
#    - Requires 2-4GB RAM for the model

# ---------------------------------------------------------------------------
# PDF ingestion
# ---------------------------------------------------------------------------
# PDF_UPLOAD_DIR is the directory where uploaded statement PDFs are
# stored. Relative paths resolve against the project root. The path
# is created on first upload.
PDF_UPLOAD_DIR=shared
# MAX_FILE_SIZE_MB caps the upload size. Exceeding it returns
# 413 Payload Too Large from the upload route.
MAX_FILE_SIZE_MB=10

# ---------------------------------------------------------------------------
# Test-only — integration / E2E test fixtures
# ---------------------------------------------------------------------------
# TEST_RUT is the cardholder RUT the integration and E2E test
# suites use to derive per-bank PDF passwords and decrypt the
# sample statements in shared/account-state-examples/. It is
# intentionally *not* set in the repo: leaving it unset makes the
# integration tests skip (the real identifier never has to be
# committed), and setting it locally lets the same suite exercise
# the real PDFs. Uncomment and set to your own RUT to run the
# full suite end-to-end:
#
#   TEST_RUT=12.345.678-9
#
# Format: standard Chilean RUT (body, optional ``-``, digit or ``K``).
# Whitespace, dots, and the verification digit are all accepted.
TEST_RUT=

# ---------------------------------------------------------------------------
# Docker deployment
# ---------------------------------------------------------------------------
# The values below are the *container-side* paths the bundled
# ``docker-compose.yml`` expects. Override them in your local
# ``.env`` only if you have changed the compose file's bind
# mounts to point somewhere else.
#
#   DATABASE_URL    Path *inside* the container; the compose
#                   file bind-mounts ``./data`` to
#                   ``/app/data``, so this is the canonical
#                   location for the SQLite database file.
#   PDF_UPLOAD_DIR  Path *inside* the container; the compose
#                   file bind-mounts ``./shared`` to
#                   ``/app/shared``, so this is the canonical
#                   location for uploaded statement PDFs.
#
# If you are running the app without Docker (the default
# workflow), the values in the Database and PDF ingestion
# sections above already point at the right local paths.
#
# DATABASE_URL=sqlite+aiosqlite:////app/data/finhealth.db
# PDF_UPLOAD_DIR=/app/shared
